{
    "build": {
        "image": "esp-dev:latest",
        "dockerfile": "../docker/dev.dockerfile",
        "context": "..",
        "args": {
            "UID": "${localEnv:UID:1000}",
            "GID": "${localEnv:GID:1000}"
        }
    },
    "privileged": true,
	"runArgs": ["--network=host"],
    "customizations": {
        "vscode": {
            "extensions": [
                "llvm-vs-code-extensions.vscode-clangd",
                "ms-azuretools.vscode-docker",
                "mhutchie.git-graph",
                "twxs.cmake",
                "ms-vscode.cmake-tools",
                "zxh404.vscode-proto3",
                "ms-vscode.cpptools",
                "hediet.vscode-drawio",
                "github.vscode-github-actions",
                "GitHub.vscode-pull-request-github",
                "systemticks.c4-dsl-extension"
            ],
            "settings": {
                "clangd.path": "/opt/esp/tools/esp-clang/esp-20.1.1_20250829/esp-clang/bin/clangd", 
                "clangd.arguments": ["--query-driver=/opt/esp/tools/xtensa-esp-elf/esp-15.2.0_20251204/xtensa-esp-elf/bin/xtensa-esp32s2-elf-gcc,/opt/esp/tools/xtensa-esp-elf/esp-15.2.0_20251204/xtensa-esp-elf/bin/xtensa-esp32s2-elf-g++"],
                "editor.tabSize": 4,
                "editor.insertSpaces": true,
                "editor.indentSize": "tabSize",
                "editor.detectIndentation": false,
                "[*]": {
                    "editor.tabSize": 4,
                    "editor.insertSpaces": true,
                    "editor.indentSize": "tabSize"
                }
            }
        }
    },
    "workspaceFolder": "/workspace",
    "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
    "mounts": [
        "source=/dev,target=/dev,type=bind",
        "source=${localEnv:HOME}/.ssh,target=/home/developer/.ssh,type=bind"
    ]
}