{
    "build": {
        "image": "esp-dev:latest",
        "dockerfile": "../docker/dev.dockerfile",
        "context": "..",
        "args": {
            "UID": "${localEnv:UID:1000}",
            "GID": "${localEnv:GID:1000}",
            "USERNAME": "${localEnv:USER:developer}"
        }
    },
    "privileged": true,
	"runArgs": ["--network=host"],
    "customizations": {
        "vscode": {
            "extensions": [
                "llvm-vs-code-extensions.vscode-clangd",
                "ms-azuretools.vscode-docker",
                "mhutchie.git-graph",
                "twxs.cmake",
                "ms-vscode.cmake-tools",
                "zxh404.vscode-proto3",
                "ms-vscode.cpptools",
                "hediet.vscode-drawio",
                "github.vscode-github-actions",
                "GitHub.vscode-pull-request-github",
                "systemticks.c4-dsl-extension"
            ],
            "settings": {
                "clangd.path": "/usr/local/bin/clangd",
                "clangd.arguments": [
                    "--query-driver=/opt/esp/tools/xtensa-esp-elf/*/xtensa-esp-elf/bin/xtensa-esp*-elf-gcc,/opt/esp/tools/xtensa-esp-elf/*/xtensa-esp-elf/bin/xtensa-esp*-elf-g++",
                    "--compile-commands-dir=/workspace/build"
                ],
                "editor.tabSize": 4,
                "editor.insertSpaces": true,
                "editor.indentSize": "tabSize",
                "editor.detectIndentation": false,
                "[*]": {
                    "editor.tabSize": 4,
                    "editor.insertSpaces": true,
                    "editor.indentSize": "tabSize"
                }
            }
        }
    },
    "workspaceFolder": "/workspace",
    "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
    "mounts": [
        "source=/dev,target=/dev,type=bind",
        "source=${localEnv:HOME}/.ssh,target=/home/developer/.ssh,type=bind"
    ]
}